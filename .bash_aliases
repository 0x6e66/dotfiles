# aliases
alias ll='ls -lh'
alias la='ls -Alh'
alias l='ls -CF'
alias df='df -h'
alias rm='rm -I'
alias du='du -sh'

alias ..='cd ..'

alias update='sudo pacman -Syu && yay -Syu --noconfirm'

alias v="nvim"

alias gc="cd ~/git; git clone "
alias gs="git status"
alias gm="git commit "
alias gp="git push"
alias gd="git diff"
alias ga="git add"

